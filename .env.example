BOT_TOKEN=

# Telegram chat_id владельца (получит super_owner при первом запуске)
SUPER_OWNER_CHAT_ID=

# WireGuard
WG_INTERFACE=wg0
WG_CONF=/etc/wireguard/wg0.conf
SERVER_ENDPOINT=1.2.3.4:51820
SERVER_PUBLIC_KEY=
VPN_SUBNET=10.8.0.0/22
DNS_IP=1.1.1.1
KEEPALIVE=25

# Пути хранения данных проекта
PROJECT_DIR=./
CLIENTS_DIR=./clients
DB_PATH=./clients/wg-bot.db
CHAT_DIR=./chat

# Поддержка и лимиты
SUPPORT_HANDLE=@support
DEFAULT_USER_LIMIT=3
ADMIN_LIMIT=999

# Ссылка на веб-мониторинг для кнопки "Мониторинг" в админке бота
MONITOR_URL=

# Веб-мониторинг (FastAPI)
# Важно: укажи свой секрет в проде
WEB_SECRET=change-me-monitor-secret
WEB_PORT=8080
MONITOR_POLL_SEC=30
MONITOR_KEEP_DAYS=90
MONITOR_DNS_CACHE_DAYS=7

# Мониторинг uplink-интерфейсов (бот)
UPLINK_HEALTHCHECK_INTERVAL_SEC=60
UPLINK_HANDSHAKE_STALE_SEC=60
UPLINK_DOWN_CONFIRM_COUNT=2
UPLINK_UP_CONFIRM_COUNT=2
UPLINK_ALERT_DOWN_ON_START=1
