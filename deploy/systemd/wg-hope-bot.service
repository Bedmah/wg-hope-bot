[Unit]
Description=WG Hope Telegram Bot
After=network-online.target wg-quick@wg0.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/wg-hope-bot
EnvironmentFile=/opt/wg-hope-bot/.env
ExecStart=/opt/wg-hope-bot/.venv/bin/python /opt/wg-hope-bot/bot.py
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
